# Test Environment Variables
# Copy this to .env and fill in your values

# API Configuration
API_URL=http://localhost:5000

# Database (should match backend/.env)
DATABASE_URL=postgresql://user:password@localhost:5432/cognitive_canvas_test

# JWT Secret (should match backend/.env)
JWT_SECRET=your-test-jwt-secret-key

# Claude API Key (should match backend/.env)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Test Configuration
NODE_ENV=test
